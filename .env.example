# ─── Firebase ────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your Firebase project credentials.
# NEVER commit .env.local to version control.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── App ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="MenuLab CR"
VITE_APP_ENV=development

# ─── Emulators ────────────────────────────────────────────────────────────────
# Set to "true" to connect to Firebase Emulator Suite instead of production.
VITE_USE_EMULATOR=false

# ─── Multi-Tenant ─────────────────────────────────────────────────────────────
# In production, tenant ID is resolved from subdomain or QR param.
# For local dev, override manually.
VITE_DEV_TENANT_ID=soda-la-rustica

# ─── Cloudinary (image hosting) ───────────────────────────────────────────────
# Required for dish image uploads. Get values from your Cloudinary dashboard.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# ─── Gemini AI (optional — menu digitalization) ──────────────────────────────
# La clave ahora vive en Vercel como GEMINI_API_KEY. Para local, puedes crear un archivo .env.local
# y agregarla sin el VITE_, o usar Vercel CLI (vercel dev) para que tome la nube.
