rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Verified via Firestore members subcollection — never trusts JWT claims alone.
    // Cost: 1 extra read per write operation (acceptable for admin-only paths).
    function isTenantMember(tenantId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid));
    }

    function isTenantOwner(tenantId) {
      return isAuthenticated()
        && get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid)).data.role == 'owner';
    }

    // ── Tenants ───────────────────────────────────────────────────────────────
    match /tenants/{tenantId} {
      // Public read: required for QR customer views (branding, feature flags, template refs)
      allow read: if true;
      // Self-serve bootstrap: un usuario autenticado puede CREAR un tenant nuevo
      // solo si se pone a sí mismo como ownerId. `create` no dispara si el doc ya
      // existe, así que no puede sobreescribir un tenant ajeno.
      allow create: if isAuthenticated()
                    && request.resource.data.ownerId == request.auth.uid;
      // El owner puede cambiar todo. El staff (member) puede actualizar SOLO
      // la promo del día y el infoFooter (horario/dirección/teléfono) — nada más
      // del branding ni del tenant. Se valida con diff de mapas anidados.
      allow update: if isTenantOwner(tenantId)
                    || (isTenantMember(tenantId)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['branding', 'updatedAt'])
                        && request.resource.data.branding.diff(resource.data.branding).affectedKeys().hasOnly(['promo', 'infoFooter']));
      allow delete: if isTenantOwner(tenantId);

      // ── Members (internal — never expose full list to customers) ─────────────
      match /members/{userId} {
        allow read:  if isTenantMember(tenantId);
        // Bootstrap: el usuario puede crear SU propia membresía owner, pero solo
        // en un tenant cuyo ownerId ya es él (no puede unirse a tenants ajenos).
        // O BIEN: el owner crea una cuenta de staff (rol 'staff') en su tenant.
        allow create: if (isAuthenticated()
                          && userId == request.auth.uid
                          && request.resource.data.role == 'owner'
                          && get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid)
                       || (isTenantOwner(tenantId)
                          && request.resource.data.role == 'staff');
        // Gestión posterior de miembros: solo el owner.
        allow update, delete: if isTenantOwner(tenantId);
      }

      // ── Menus ─────────────────────────────────────────────────────────────────
      match /menus/{menuId} {
        allow read:  if true;
        allow write: if isTenantMember(tenantId);

        // ── Dishes (nested under menu — firestorePaths pattern) ───────────────
        match /dishes/{dishId} {
          allow read:  if true;
          allow write: if isTenantMember(tenantId);
        }

        // ── Categories (nested under menu — firestorePaths pattern) ──────────
        match /categories/{categoryId} {
          allow read:  if true;
          allow write: if isTenantMember(tenantId);
        }
      }

      // ── Dishes top-level (PATHS.tenantDish — flat pattern) ───────────────────
      // Covers the PATHS constant in shared/constants/firestore-paths.ts which
      // writes dishes directly under the tenant document, not nested under menus.
      match /dishes/{dishId} {
        allow read:  if true;
        allow write: if isTenantMember(tenantId);
      }

      // ── Categories top-level (PATHS.tenantCategories — flat pattern) ─────────
      match /categories/{categoryId} {
        allow read:  if true;
        allow write: if isTenantMember(tenantId);
      }

      // ── Tables ────────────────────────────────────────────────────────────────
      match /tables/{tableId} {
        allow read:  if true;
        allow write: if isTenantMember(tenantId);
      }

      // ── Settings (singleton config document) ─────────────────────────────────
      // Path: tenants/{tenantId}/settings/config (firestorePaths.settings)
      match /settings/{docId} {
        allow read:  if isTenantMember(tenantId);
        allow write: if isTenantOwner(tenantId);
      }

      // ── Appearance Preview (Live Sync) ──────────────────────────────────────
      match /appearancePreview/{docId} {
        allow read: if true;
        allow create, delete: if isTenantMember(tenantId);
        allow update: if isTenantMember(tenantId)
                      || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['phoneActive']));
      }

      // ── Editor namespace — drafts + published document (Núcleo v2) ───────────
      // Covers:
      //   PATHS.editor.published  → tenants/{id}/editor/published  (singleton)
      //   PATHS.editor.draft      → tenants/{id}/editor/drafts/{snapshotId}
      // The {allPaths=**} wildcard captures both the singleton and the drafts
      // subcollection at any depth without exposing them publicly.
      match /editor/{allPaths=**} {
        allow read:  if isTenantMember(tenantId);
        allow write: if isTenantMember(tenantId);
        // delete (prune old drafts) — members only, not owner-restricted,
        // because useEditorAutosave pruning runs in the client session.
        allow delete: if isTenantMember(tenantId);
      }

      // ── Analytics events (raw, written by QR customers anonymously) ──────────
      match /analyticsEvents/{eventId} {
        allow read:          if isTenantMember(tenantId);
        allow create:        if true;        // anonymous QR scan events
        allow update, delete: if false;      // immutable — Cloud Functions aggregate
      }

      // ── Analytics daily summaries (Cloud Functions only via Admin SDK) ────────
      match /analyticsDailySummaries/{date} {
        allow read:  if isTenantMember(tenantId);
        allow write: if false; // Admin SDK bypasses rules
      }

      // ── Orders (pedidos en línea desde QR + POS) ──────────────────────────────
      // Los clientes anónimos crean pedidos desde la carta pública; solo el
      // restaurante puede leerlos y avanzar el estado. Nunca se borran.
      match /orders/{orderId} {
        allow create: if request.resource.data.tenantId == tenantId;
        allow read, update: if isTenantMember(tenantId);
        allow delete: if false;
      }

      // ── Reservations (reservas desde QR + admin) ──────────────────────────────
      match /reservations/{reservationId} {
        allow create: if request.resource.data.tenantId == tenantId;
        allow read, update: if isTenantMember(tenantId);
        allow delete: if false;
      }

      // ── Loyalty cards (sellos digitales — solo el restaurante las gestiona) ───
      match /loyalty_cards/{cardId} {
        allow read, write: if isTenantMember(tenantId);
      }

      // ── CRM customers (datos sensibles — solo el restaurante) ─────────────────
      // create también permitido sin auth: el upsert ocurre al crear un pedido
      // público con teléfono. update sin auth solo vía merge del mismo flujo.
      match /customers/{customerId} {
        allow create, update: if true;
        allow read:   if isTenantMember(tenantId);
        allow delete: if false;
      }

      // ── Inventory (ingredientes, recetas, movimientos) ────────────────────────
      match /ingredients/{ingredientId} {
        allow read, write: if isTenantMember(tenantId);
      }
      match /recipes/{dishId} {
        allow read, write: if isTenantMember(tenantId);
      }
      match /stock_movements/{movementId} {
        allow read, create: if isTenantMember(tenantId);
        allow update, delete: if false; // ledger inmutable
      }

      // ── Payments (cierres de cuenta POS — inmutables) ─────────────────────────
      match /payments/{paymentId} {
        allow read, create: if isTenantMember(tenantId);
        allow update, delete: if false;
      }

      // ── Employees (PINs hasheados — nunca expuestos al público) ───────────────
      match /employees/{employeeId} {
        allow read, write: if isTenantMember(tenantId);
      }

      // ── Notifications (in-app del admin) ──────────────────────────────────────
      // create público: los side-effects de pedidos/reservas de clientes anónimos
      // generan la notificación. Lectura y gestión solo del restaurante.
      match /notifications/{notificationId} {
        allow create: if request.resource.data.tenantId == tenantId;
        allow read, update, delete: if isTenantMember(tenantId);
      }

      // ── Billing (suscripción — solo lectura desde el cliente) ─────────────────
      match /billing/{docId} {
        allow read:  if isTenantMember(tenantId);
        allow write: if false; // gestionado vía Admin SDK / plataforma
      }
    }

    // ── User accounts (top-level uid → tenantId mapping) ───────────────────────
    // Escrito por el provisioning self-serve del cliente: cada usuario solo puede
    // crear/editar SU propio doc. Es solo una pista de resolución de tenant —
    // todas las escrituras reales siguen protegidas por la membresía del tenant.
    match /users/{userId} {
      allow read:          if isAuthenticated() && request.auth.uid == userId;
      // El usuario gestiona su propio mapping; o el owner crea/actualiza el de
      // una cuenta de staff que apunta a SU tenant (rol 'staff').
      allow create, update: if (isAuthenticated() && request.auth.uid == userId)
                            || (request.resource.data.role == 'staff'
                               && isTenantOwner(request.resource.data.tenantId));
      allow delete:        if false;
    }

    // ── Quotes (leads del flujo "Cotizar con nosotros") ────────────────────────
    // Cualquier visitante puede enviar un lead. Nadie puede leerlos/editarlos
    // desde el cliente — se revisan vía consola/Admin SDK (panel interno futuro).
    match /quotes/{quoteId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ── Collection Group: Dishes ──────────────────────────────────────────────
    // Permite consultas collectionGroup sobre platos de manera segura,
    // asegurando que solo miembros del tenant correspondiente puedan leerlos.
    match /{path=**}/dishes/{dishId} {
      allow read: if resource.data.tenantId != null && isTenantMember(resource.data.tenantId);
    }

    // ── Deny everything else explicitly ───────────────────────────────────────
    // Cualquier ruta no contemplada arriba se deniega. (ANTES estaba en `if true`,
    // lo que abría TODA la base de datos a lectura/escritura pública — agujero de
    // seguridad crítico. Ahora deny-by-default, coherente con el comentario.)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
